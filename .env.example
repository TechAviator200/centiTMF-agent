# ============================================================
# centiTMF — Environment Variable Reference
# ============================================================
# Copy this file to .env for local development.
# In production, set these variables in your hosting dashboard
# (Render for backend, Vercel for frontend) — never commit .env.
# ============================================================


# ── AI (optional) ────────────────────────────────────────────
# When set, enables GPT-4o narrative generation and enhanced Audit Questions.
# The system works without this key using deterministic fallbacks.
OPENAI_API_KEY=


# ── Database ─────────────────────────────────────────────────
# LOCAL: Leave these blank to use Docker Compose defaults (postgres container).
# PRODUCTION (Supabase): Set to your Supabase connection strings.
#
# DATABASE_URL     — async URL for the FastAPI app (asyncpg driver).
#   Supabase format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#   Note: postgres:// and postgresql:// are both accepted and normalized automatically.
#
# SYNC_DATABASE_URL — sync URL for the seed script (psycopg2 driver).
#   If not set, derived from DATABASE_URL automatically.
#   Supabase format: postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
#
DATABASE_URL=
SYNC_DATABASE_URL=


# ── Object Storage (S3-compatible) ───────────────────────────
# LOCAL: Uses the MinIO container started by Docker Compose.
# PRODUCTION: Use Cloudflare R2 (or any S3-compatible provider).
#
# Cloudflare R2:
#   S3_ENDPOINT_URL  = https://<account-id>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY    = R2 Access Key ID
#   S3_SECRET_KEY    = R2 Secret Access Key
#   S3_BUCKET        = your pre-created bucket name
#   AWS_REGION       = auto  (required for R2)
#
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
AWS_REGION=auto


# ── Runtime ──────────────────────────────────────────────────
# PORT is set automatically by Render. Do not set it manually in production.
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ── Frontend (Vercel) ────────────────────────────────────────
# Set these in the Vercel dashboard when deploying the frontend.
# NEXT_PUBLIC_API_URL  — public URL of the Render backend (used by the browser).
# INTERNAL_API_URL     — same Render URL, used by Vercel SSR/RSC server-side fetches.
#
# Example:
#   NEXT_PUBLIC_API_URL=https://centitmf-backend.onrender.com
#   INTERNAL_API_URL=https://centitmf-backend.onrender.com
#
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=
